{
  "name": "telesculpt-api",
  "version": "1.0.0",
  "description": "TeleSculpt backend - Azure Functions v4 (Node.js programming model v4)",
  "main": "src/functions/*.js",
  "scripts": {
    "start": "func start",
    "setup-local": "node scripts/setup-local.js",
